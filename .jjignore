# Generated by https://www.toptal.com/developers/gitignore/api/rust
# Edit at https://www.toptal.com/developers/gitignore?templates=rust

### Rust ###
# Standard target directory for compiled Rust binaries
/target/

# Cargo files
Cargo.lock
# `Cargo.lock` is not ignored in a binary crate, but is ignored in a library crate.
# This project is a virtual workspace, which contains both binary and library crates.
# We'll ignore it at the root, but individual crates might have their own.

# Generated documentation
/doc/
/docs/

# Build artifacts
/*.d
/*.o
/*.rlib
/*.so
/*.dll
/*.dylib
/deps/
/examples/target/

# IDE files
.idea/
.vscode/
*.iml
*.iws

# OS generated files
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*

# Local development and testing
/coverage/
/pkg/

# Editor backup files
*~
*.bak
*.swp
.fuse_hidden*

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS-specific temporary files
tmp/
.temp/

# Crates generated by tools
/crates/
# This is a special case for a virtual workspace where `crates/` contains actual crates.
# We will explicitly *not* ignore the `crates/` directory itself, but rather
# ignore the `target/` directories inside each crate.

# Custom additions for projini:
# Ignore JetBrains related files, which may be generated when using IntelliJ Rust plugin
*.iml
.idea
.fleet
.project
.settings
.classpath
.cproject
.externalToolBuilders
.buildpath

# Ignore jj-related internal files
.jj/

# Qodo
.qodo/
